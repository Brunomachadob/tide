{
  "name": "tide-scheduler",
  "version": "1.0.0",
  "description": "macOS task scheduler with a terminal UI — run any command on a schedule using launchd",
  "type": "module",
  "bin": {
    "tide": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brunomachadob/tide.git"
  },
  "keywords": [
    "scheduler",
    "launchd",
    "macos",
    "cron",
    "tui"
