{
  "name": "tide-scheduler",
  "version": "1.0.0",
  "description": "macOS task scheduler with a terminal UI — run any command on a schedule using launchd",
  "type": "module",
  "bin": {
    "tide": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.js",
    "test:ci": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=tap --test-reporter-destination=tap-output.txt test/*.test.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4",
    "vitepress-plugin-tabs": "^0.8.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@github/copilot-sdk": "^0.2.1",
    "ai": "^6.0.145",
    "ai-sdk-provider-gemini-cli": "^2.0.1",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brunomachadob/tide.git"
  },
  "keywords": [
    "scheduler",
    "launchd",
    "macos",
    "cron",
    "tui"
  ],
  "author": "Bruno Brandao",
  "license": "MIT"
}
